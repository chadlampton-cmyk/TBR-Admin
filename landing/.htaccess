DirectoryIndex index.html

RewriteEngine On

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+hello\.html[\s?] [NC]
RewriteRule ^hello\.html$ /lounge [R=301,L]

RewriteCond %{THE_REQUEST} \s/+settings\.html[\s?] [NC]
RewriteRule ^settings\.html$ /settings [R=301,L]

RewriteCond %{THE_REQUEST} \s/+help\.html[\s?] [NC]
RewriteRule ^help\.html$ /help [R=301,L]

RewriteCond %{THE_REQUEST} \s/+profile\.html[\s?] [NC]
RewriteRule ^profile\.html$ /profile [R=301,L]

RewriteCond %{THE_REQUEST} \s/+register\.html[\s?] [NC]
RewriteRule ^register\.html$ /register [R=301,L]

RewriteRule ^lounge/?$ /hello.html [L]
RewriteRule ^settings/?$ /settings.html [L]
RewriteRule ^help/?$ /help.html [L]
RewriteRule ^profile/?$ /profile.html [L]
RewriteRule ^register/?$ /register.html [L]
